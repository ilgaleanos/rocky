{
  "backend_url": "http://localhost:8080",
  "global_whitelist": [],
  "trusted_proxies": [],
  "routes": [
    {
      "path": "/admin/auth/**",
      "rules": [
        {
          "identifiers": ["ip"],
          "limit": 4,
          "window_secs": 30,
          "on_limit_exceeded": { "duration_secs": 60 }
        }
      ]
    },
    {
      "path": "/api/security/**",
      "rules": [
        {
          "identifiers": ["ip"],
          "limit": 4,
          "window_secs": 60,
          "on_limit_exceeded": { "duration_secs": 60 }
        }
      ]
    },
    {
      "path": "/api/web/**",
      "rules": [
        {
          "identifiers": ["header:authorization"],
          "limit": 10,
          "window_secs": 30,
          "on_limit_exceeded": { "duration_secs": 30 }
        }
      ]
    },
    {
      "path": "/**",
      "rules": [
        {
          "identifiers": ["ip"],
          "limit": 1000,
          "window_secs": 10,
          "on_limit_exceeded": { "duration_secs": 10 }
        }
      ]
    }
  ]
}
